++++# Total: ~7.6 MB, fits in 8 MB flash. For 16 MB boards, enlarge ota_0/ota_1
++++# and/or littlefs.
++++
++++# Name,     Type, SubType,  Offset,   Size,    Flags
++++nvs,        data, nvs,      0x9000,   0x6000,
++++phy_init,   data, phy,      0xf000,   0x1000,
++++otadata,    data, ota,      0x10000,  0x2000,
